        {
          "name": "Shopper Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let res = pm.response.json();\r",
                  "let token = res.data.jwtToken;\r",
                  "\r",
                  "pm.environment.set(\"jwtToken\", token);\r",
                  "\r",
                  "pm.test(\"Validate schema\", function () {\r",
                  "    const schema = {\r",
                  "        type: \"object\",\r",
                  "        properties: {\r",
                  "            statusCode: { type: \"number\" },\r",
                  "            message: { type: \"string\" },\r",
                  "            data: {\r",
                  "                type: \"object\",\r",
                  "                properties: {\r",
                  "                    userId: { type: \"number\" },\r",
                  "                    email: { type: \"string\" },\r",
                  "                    role: { type: \"string\" },\r",
                  "                    status: { type: \"string\" },\r",
                  "                    createdDateTime: { type: [\"string\", \"null\"] },\r",
                  "                    firstName: { type: \"string\" },\r",
                  "                    lastName: { type: \"string\" },\r",
                  "                    city: { type: \"string\" },\r",
                  "                    state: { type: \"string\" },\r",
                  "                    country: { type: \"string\" },\r",
                  "                    zoneId: { type: \"string\" },\r",
                  "                    imageId: { type: [\"string\", \"null\"] },\r",
                  "                    jwtToken: { type: \"string\" }\r",
                  "                },\r",
                  "                required: [\r",
                  "                    \"userId\",\r",
                  "                    \"email\",\r",
                  "                    \"role\",\r",
                  "                    \"status\",\r",
                  "                    \"createdDateTime\",\r",
                  "                    \"firstName\",\r",
                  "                    \"lastName\",\r",
                  "                    \"city\",\r",
                  "                    \"state\",\r",
                  "                    \"country\",\r",
                  "                    \"zoneId\",\r",
                  "                    \"imageId\",\r",
                  "                    \"jwtToken\"\r",
                  "                ]\r",
                  "            }\r",
                  "        },\r",
                  "        required: [\"statusCode\", \"message\", \"data\"]\r",
                  "    };\r",
                  "\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
